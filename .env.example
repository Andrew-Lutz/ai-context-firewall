# ==================================================
# AI Context Firewall - Environment Configuration
# ==================================================
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# --- Application ---
APP_ENV=production
APP_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
APP_DEBUG=false
LOG_LEVEL=INFO
API_VERSION=v1

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=firewall_db
POSTGRES_USER=firewall_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://firewall_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/firewall_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# --- JWT ---
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM Providers ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL=gpt-4o

# --- Encryption ---
ENCRYPTION_KEY=CHANGE_ME_USE_FERNET_GENERATE_KEY
TOKEN_VAULT_SALT=CHANGE_ME_RANDOM_SALT_32_CHARS

# --- Redaction ---
REDACTION_MODE=mask          # mask | hash | tokenize
ENABLE_REVERSIBLE_TOKENS=true
TOKEN_VAULT_TTL_HOURS=24

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# --- Observability ---
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# --- Storage ---
FILE_UPLOAD_MAX_MB=50
ALLOWED_FILE_TYPES=pdf,csv,json,txt,docx,eml

# --- Multi-tenancy ---
DEFAULT_TENANT_ID=default
MAX_TENANTS=100

# --- Vector DB (optional) ---
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
WEAVIATE_URL=

# --- Kafka (optional) ---
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC_AUDIT=firewall.audit
KAFKA_TOPIC_ALERTS=firewall.alerts

# --- Email Alerts ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=firewall@your-org.com
ALERT_EMAIL_TO=security@your-org.com
